{
  "name": "nostrum",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "typecheck": "tsc -b",
    "test": "bun test",
    "smoke": "bun run scripts/smoke.ts",
    "smoke:https": "bun run scripts/smoke-https-first.ts",
    "smoke:strict": "bun run scripts/smoke-strict.ts",
    "bench": "bun run scripts/bench.ts",
    "bench-nostream": "bun run scripts/bench-nostream.ts",
    "bench-remote": "RELAY_URL=wss://testrelay.era21.space SKIP_DOCKER=1 bun run scripts/bench-remote.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/bun": "^1.1.13",
    "@nostrum/core": "workspace:*",
    "@nostrum/ndk-adapters": "workspace:*",
    "@nostrum/nostr-tools-adapters": "workspace:*",
    "@nostrum/server": "workspace:*",
    "@nostrum/client": "workspace:*",
    "@nostr-dev-kit/ndk": "^2.12.0",
    "hono": "^4.6.0"
  },
  "engines": {
    "bun": ">=1.1.30"
  }
}
